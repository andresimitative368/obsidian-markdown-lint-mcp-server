{
  "$comment": "Shared definitions referenced by all note type schemas. Not a standalone schema.",
  "$defs": {
    "coreFields": {
      "required": ["type", "title", "author", "category", "tags", "description", "summary", "status", "version", "date_created", "date_updated"],
      "properties": {
        "title": { "type": "string", "minLength": 1 },
        "author": { "type": "string", "minLength": 1 },
        "category": {
          "type": "string",
          "enum": [
            "Artificial Intelligence", "Business Management", "Cloud Computing",
            "Critical Thinking", "Database", "Decision Making", "DevOps",
            "Documentation", "Education", "Entrepreneurship", "Finance",
            "How-To", "Leadership", "Legal & Compliance", "Marketing",
            "Mental Health", "Methodology", "Mobile Development", "Monitoring",
            "Operations", "Personal Development", "Product Management",
            "Productivity", "Project Management", "Security",
            "Software Architecture", "Software Development", "Software Engineering",
            "Strategy", "Web Development"
          ]
        },
        "tags": {
          "type": "array",
          "items": { "type": "string", "pattern": "^[a-z0-9][a-z0-9_\\-/]*$" },
          "minItems": 4,
          "maxItems": 12
        },
        "description": { "type": "string", "minLength": 1 },
        "summary": { "type": "string", "minLength": 1 },
        "status": { "type": "string", "enum": ["published", "draft", "in-progress"] },
        "version": { "type": "string", "pattern": "^\\d+\\.\\d+\\.\\d+$" },
        "date_created": { "type": "string", "format": "date" },
        "date_updated": { "type": "string", "format": "date" }
      }
    },
    "reviewFields": {
      "properties": {
        "reviewers": { "type": "array", "items": { "type": "string" } },
        "next_reviewer": { "type": "array", "items": { "type": "string" } },
        "next_review_date": { "type": "string", "format": "date" },
        "signoff": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "date"],
            "properties": {
              "name": { "type": "string" },
              "date": { "type": "string", "format": "date" }
            }
          }
        },
        "revision_notes": { "type": "array", "items": { "type": "string" } },
        "published": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "when": { "type": "string", "format": "date" },
              "where": { "type": "string" },
              "version": { "type": "string" }
            }
          }
        },
        "backup": { "type": "string" }
      }
    },
    "commonOptionalFields": {
      "properties": {
        "aliases": { "type": "array", "items": { "type": "string" } },
        "subtitle": { "type": "string" },
        "read_time": { "type": "string" },
        "source": { "type": "string" },
        "sources": { "type": "array", "items": { "type": "string" } },
        "mermaid_theme": { "type": "string", "enum": ["default", "dark", "neutral", "forest"] },
        "mermaid_background": { "type": "string" },
        "mermaid_svg_source": { "type": "string" }
      }
    }
  }
}
